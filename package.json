{
  "name": "unforget",
  "version": "0.1.0",
  "description": "re-inject working state lost when Claude Code compacts context",
  "type": "module",
  "bin": {
    "unforget": "dist/cli.mjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.3"
  },
  "scripts": {
    "build": "tsdown && node dist/cli.mjs --version >/dev/null",
    "dev": "bun src/cli.ts",
    "test": "bun test",
    "lint": "biome check src test",
    "retro": "bun bench/retro.ts",
    "format": "biome check --write src test",
    "typecheck": "tsc --noEmit",
    "prepare": "bun run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "compaction",
    "context",
    "hook",
    "cli"
  ],
  "license": "MIT",
  "author": "rupaut98",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rupaut98/unforget.git"
  },
  "homepage": "https://github.com/rupaut98/unforget#readme",
  "bugs": "https://github.com/rupaut98/unforget/issues",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.7.2"
  }
}
